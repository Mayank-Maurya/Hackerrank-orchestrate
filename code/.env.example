# Copy this file to .env and fill in your key. .env is gitignored.
# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model selection (override only if you need to)
GEMINI_TRIAGE_MODEL=gemini-2.0-flash
GEMINI_CLASSIFY_MODEL=gemini-2.0-flash
GEMINI_DRAFT_MODEL=gemini-2.0-flash
GEMINI_VALIDATE_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
